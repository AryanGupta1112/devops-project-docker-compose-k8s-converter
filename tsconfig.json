{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/backend",
    "rootDir": "src/main/backend/src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/main/backend/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/main/frontend"]
}
