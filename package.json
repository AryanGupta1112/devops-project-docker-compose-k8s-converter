{
  "name": "docker-compose-k8s-converter",
  "version": "1.0.0",
  "private": true,
  "description": "Intermediate DevOps project: Docker Compose to Kubernetes converter",
  "main": "dist/backend/server.js",
  "scripts": {
    "dev": "tsx watch src/main/backend/src/server.ts",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "npm --prefix src/main/frontend run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node dist/backend/server.js",
    "lint": "eslint \"src/main/backend/src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:unit": "jest --config jest.config.cjs tests/unit --runInBand",
    "test:integration": "jest --config jest.config.cjs tests/integration --runInBand"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "multer": "^2.0.2",
    "pino": "^9.9.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
